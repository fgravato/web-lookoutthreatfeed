false’ (default) controlling\nwhether Lookout ingests or rejects the feed for analysis.\nLookout does not tag the data with any customer-identifying information.\n","operationId":"createFeed","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateFeedRequest"},"example":{"title":"feed-title","description":"feed-description","feedType":"CSV","allowAnalysis":false}}},"required":true},"responses":{"401":{"description":"Invalid authentication"},"400":{"description":"Bad Request","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"500":{"description":"Internal Server Error.","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"201":{"description":"Created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateFeedResponse"}}}}}}}},"components":{"schemas":{"UpdateFeedRequest":{"type":"object","properties":{"title":{"maxLength":255,"minLength":8,"type":"string","description":"New Feed Title"},"description":{"maxLength":255,"minLength":8,"type":"string","description":"New Feed Description"},"allowAnalysis":{"type":"boolean","description":"Allow feed element analysis"}}},"ProblemDetail":{"type":"object","properties":{"type":{"type":"string","format":"uri"},"title":{"type":"string"},"status":{"type":"integer","format":"int32"},"detail":{"type":"string"},"instance":{"type":"string","format":"uri"},"properties":{"type":"object","additionalProperties":{"type":"object"}}}},"IncrementalUpdateOperation":{"type":"object","properties":{"domain":{"type":"string"},"action":{"type":"string","enum":["add","delete"]}}},"IncrementalUpdateRequest":{"type":"object","properties":{"operations":{"type":"array","items":{"$ref":"#/components/schemas/IncrementalUpdateOperation"}}}},"IncrementalUpdateError":{"type":"object","properties":{"index":{"type":"integer","format":"int64"},"operation":{"$ref":"#/components/schemas/IncrementalUpdateOperation"},"errorCode":{"type":"string"},"errorMessage":{"type":"string"}}},"IncrementalUpdateResponse":{"type":"object","properties":{"errors":{"type":"array","items":{"$ref":"#/components/schemas/IncrementalUpdateError"}}}},"CreateFeedRequest":{"required":["feedType","title"],"type":"object","properties":{"title":{"maxLength":255,"minLength":8,"type":"string","description":"Feed Title"},"description":{"maxLength":255,"minLength":8,"type":"string","description":"Feed Description"},"feedType":{"type":"string","description":"Feed Type","enum":["CSV"]},"allowAnalysis":{"type":"boolean","description":"Allow feed element analysis","default":false}}},"CreateFeedResponse":{"type":"object","properties":{"feedId":{"type":"string"}}},"GetFeedResponseDto":{"type":"object","properties":{"feedId":{"type":"string"},"title":{"type":"string"},"description":{"type":"string"},"feedType":{"type":"string"},"elementsUploadedAt":{"type":"string"},"elementsCount":{"type":"integer","format":"int32"},"allowAnalysis":{"type":"boolean"}}}},"securitySchemes":{"OAuth2-JWT":{"type":"http","scheme":"bearer","bearerFormat":"JWT"}}}}