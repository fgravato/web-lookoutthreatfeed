{"openapi":"3.0.1","info":{"title":"Threat Feed Management API","description":"Feed, once added, can be applied to business specific denylisted content policy.\n<br/> Authorize using your bearer token.\n","version":"v1"},"servers":[{"url":"https://api.lookout.com/mgmt/threat-feeds"}],"security":[{"OAuth2-JWT":[]}],"paths":{"/api/v1/threat-feeds/{feedId}":{"get":{"tags":["Feed Management API"],"summary":"Get the feed metadata","operationId":"getFeedMetadata","parameters":[{"name":"feedId","in":"path","required":true,"schema":{"type":"string"}}],"responses":{"401":{"description":"Invalid authentication"},"404":{"description":"Feed not found","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"400":{"description":"Bad Request","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"500":{"description":"Internal Server Error. The operation can be retried.","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"200":{"description":"OK","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GetFeedResponseDto"}}}}}},"put":{"tags":["Feed Management API"],"summary":"Update the feed metadata","description":"Use the _title_ and _description_ fields to identify your threat feed.\n\n_allowAnalysis_ accepts values of ‘true’ or ‘false’ (default) controlling\nwhether Lookout ingests or rejects the feed for analysis.\nLookout does not tag the data with any customer-identifying information.\n","operationId":"updateFeedMetadata","parameters":[{"name":"feedId","in":"path","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateFeedRequest"},"example":{"title":"new-feed-title","description":"new-feed-description","allowAnalysis":true}}},"required":true},"responses":{"401":{"description":"Invalid authentication"},"404":{"description":"Feed not found","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"400":{"description":"Bad Request","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"500":{"description":"Internal Server Error. The operation can be retried.","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"200":{"description":"OK"}}},"delete":{"tags":["Feed Management API"],"summary":"Delete the feed","operationId":"deleteFeed","parameters":[{"name":"feedId","in":"path","required":true,"schema":{"type":"string"}}],"responses":{"401":{"description":"Invalid authentication"},"404":{"description":"Feed not found","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"400":{"description":"Bad Request","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"500":{"description":"Internal Server Error. The operation can be retried.","content":{"application/problem+json":{"schema":{"$ref":"#/components/schemas/ProblemDetail"}}}},"200":{"description":"OK"}}}},"/api/v1/threat-feeds/{feedId}/elements/incremental-updates":{"post":{"tags":["Feed Management API"],"summary":"And and delete domains from the feed","description":"Updates the feed incrementally by performing `add` or `delete` operation\non the feed elements.\n\nEach request is limited to a maximum of 15,000 operations.\n\n## Few points related to processing\nIf there are multiple operations for the same domain are in the request body,\nonly the last one will be processed and rest will be ignored.\n","operationId":"performIncrementalUpdatesOnElements","parameters":[{"name":"feedId","in":"path","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"text/csv":{"schema":{"type":"string"},"example":"\"DOMAIN\",\"ACTION\"\n\"domains-one.com\",\"add\"\n\"domains-two.com\",\"delete\"\n"},"application/json":{"schema":{"$ref":"#/components/schemas/